# ==========================================================================
# Factory.neeklo.ru — environment example
# Copy to backend/.env (backend) and configure. Frontend uses VITE_* in frontend/.env
# ==========================================================================

# --- App ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://factory:factory@localhost:5432/factory?schema=public

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-super-secret-jwt-key
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@factory.neeklo.ru
ADMIN_PASSWORD=change-me-admin-password

# --- Encryption (AES-256-GCM) 32-byte hex (64 chars) or any passphrase ---
APP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- OpenRouter (LLM: scriptwriting + agent brain) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# --- ElevenLabs (TTS) ---
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io

# --- Avatar engines (multi-provider) ---
HEYGEN_API_KEY=
HEYGEN_BASE_URL=https://api.heygen.com
HEDRA_API_KEY=
HEDRA_BASE_URL=https://api.hedra.com
DID_API_KEY=
DID_BASE_URL=https://api.d-id.com

# --- Selectel S3 (object storage) ---
S3_ENDPOINT=https://s3.ru-3.storage.selcloud.ru
S3_REGION=ru-3
S3_BUCKET=botme
S3_ACCESS_KEY=dd858ad404f34960b6b4709815d31e23
S3_SECRET_KEY=e339eab302644bc6832bb4aa499cf2c6
S3_PUBLIC_BASE_URL=

# --- FFmpeg ---
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
